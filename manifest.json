{
  "manifest_version": 3,
  "name": "Resume Medis Reviewer",
  "version": "1.0.0",
  "description": "Side panel untuk membantu pengisian resume menggunakan AI",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Resume Medis Reviewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
