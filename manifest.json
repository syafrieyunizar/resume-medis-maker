{
  "manifest_version": 3,
  "name": "Resume Medis Helper RSBHHB",
  "version": "1.1.1",
  "description": "Side panel untuk membantu user membuat/mereview resume medis dengan menggunakan AI",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Resume Medis Helper RSBHHB"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://172.16.0.11/erms/rsud/*",
        "http://*/rsud/*",
        "https://*/rsud/*",
        "http://*/erms/rsud/*",
        "https://*/erms/rsud/*"
      ],
      "js": ["improve-inline.js"],
      "css": ["improve-inline.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
