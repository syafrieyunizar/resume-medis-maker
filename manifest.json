{
  "manifest_version": 3,
  "name": "Resume Medis Reviewer",
  "version": "1.0.0",
  "description": "Side panel untuk membantu review SO dan CPPT pasien dengan bantuan Gemini AI.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Resume Medis Reviewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://172.16.0.11/erms/rsud/*"],
      "js": ["improve-inline.js"],
      "css": ["improve-inline.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
